# ng-package-compat — server-side environment variables
#
# Copy this file to `.env` (or `.env.local`) and fill in the secrets you
# actually use. NEVER commit the real .env file — make sure it's listed
# in .gitignore.
#
# Anything in here is for the *server-side* SSR process and the bootstrap
# scripts only. The browser bundle reads from src/environments/environment.ts,
# which only contains publishable/anon keys.


# ---------- Appwrite ----------
#
# Server-side API key with these scopes:
#   databases.read, tables.read, tables.write,
#   columns.read, columns.write, indexes.read, indexes.write,
#   rows.read, rows.write
#
# Used by:
#   - scripts/bootstrap-appwrite.mjs (one-shot collection provisioning)
#   - any future server-side endpoint that writes audit/log rows
#
# Generate at: https://cloud.appwrite.io/console/project-{id}/settings/keys
APPWRITE_SERVER_KEY=

# Optional overrides — defaults match src/environments/environment.ts
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=69ecdd090037c20e762b
APPWRITE_DATABASE_ID=ngpc


# ---------- GitHub PR proxy (feature #83) ----------
#
# Server-held GitHub token used by /api/pr to open pull requests on behalf
# of the user. Use a fine-grained PAT (or a GitHub App installation token)
# scoped to the repos this proxy is allowed to write to.
GITHUB_PR_TOKEN=

# Comma-separated list of GitHub owners (orgs / users) the proxy may
# write to. Empty list = proxy refuses every request.
GITHUB_PR_OWNERS_ALLOW=


# ---------- Email digest (feature #92) ----------
#
# Provider for the digest email endpoint:
#   sendgrid | resend | console (default; logs only)
EMAIL_PROVIDER=console

# Required for sendgrid/resend:
EMAIL_FROM=
EMAIL_API_KEY=

# Optional comma-separated allow-list. If set, only these recipients
# can receive digests through the proxy.
EMAIL_RECIPIENTS_ALLOW=


# ---------- GitHub Enterprise (optional) ----------
#
# Set if you're running against GHES instead of github.com.
# Default: https://api.github.com
GITHUB_API_BASE=


# ---------- AI proxy (Groq) ----------
#
# Server-held Groq API key used by /api/ai/complete to forward chat
# completion requests. The browser never sees this key — it POSTs the
# request body to our origin and we attach the auth header server-side
# before forwarding to https://api.groq.com.
#
# Get a free key at: https://console.groq.com/keys
#
# Without this set, /api/ai/complete returns 503 and the client surfaces
# a PROXY_UNAVAILABLE error pointing the user at BYO-key alternatives.
GROQ_API_KEY=

# Optional comma-separated allow-list of Groq models the proxy will
# forward to. Default: llama-3.3-70b-versatile, llama-3.1-8b-instant,
# mixtral-8x7b-32768. Operators on paid Groq plans can extend this.
GROQ_MODELS_ALLOW=

# Optional per-IP rate limits. Defaults: 10 burst / 60s, 50 / day.
AI_PROXY_BURST_LIMIT=
AI_PROXY_DAILY_LIMIT=

# Optional. Set to "1" when running behind a CDN / reverse proxy
# (Cloudflare, Vercel, etc.) so the proxy reads the original client
# IP from X-Forwarded-For instead of the upstream's IP. Without this,
# every CDN-routed request would share one rate-limit bucket.
AI_PROXY_TRUST_FORWARDED_FOR=
