{
  "name": "ng-package-compat",
  "version": "3.0.0",
  "description": "Angular 21 app to explore npm package versions, Angular compatibility, downloads, bundle size, advisories, recommendations, and more.",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ssr": "ng build --configuration production",
    "serve:ssr": "node --env-file-if-exists=.env dist/ng-package-compat/server/server.mjs",
    "dev:proxy": "node --env-file-if-exists=.env scripts/dev-proxy.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "ngpc": "node ./cli/ngpc.mjs",
    "test:cli": "node ./cli/test.mjs",
    "setup:appwrite": "node ./scripts/bootstrap-appwrite.mjs"
  },
  "bin": {
    "ngpc": "./cli/ngpc.mjs"
  },
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "@firebase/auth": "^1.13.0",
    "@jsverse/transloco": "^8.3.0",
    "@sentry/angular": "^10.53.1",
    "@supabase/supabase-js": "^2.104.1",
    "appwrite": "^24.2.0",
    "express": "^4.19.2",
    "firebase": "^12.12.1",
    "rxjs": "~7.8.1",
    "semver": "^7.6.3",
    "tslib": "^2.6.3"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@netlify/angular-runtime": "^3.0.1",
    "@types/express": "^4.17.21",
    "@types/jasmine": "~5.1.4",
    "@types/node": "^20.14.0",
    "@types/semver": "^7.5.8",
    "jasmine-core": "~5.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "node-appwrite": "^24.0.0",
    "typescript": "~5.9.2"
  }
}
